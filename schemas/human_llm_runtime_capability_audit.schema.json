{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ZhijiWang/TRIM/schemas/human_llm_runtime_capability_audit.schema.json",
  "title": "Human-LLM runtime capability audit v0.1",
  "description": "Documented runtime candidates separated from account metadata and synthetic-inference verification.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_version",
    "audit_date",
    "record_status",
    "provider",
    "model_identifier",
    "provider_verification_record_path",
    "provider_verification_record_hash",
    "historical_runtime_draft_path",
    "historical_runtime_draft_byte_hash",
    "capabilities",
    "candidate_request_policy",
    "data_handling_boundary",
    "synthetic_inference_verification_performed",
    "runtime_frozen",
    "runtime_gate_status",
    "pricing_status",
    "final_authorization_status",
    "human_coding_status",
    "model_execution_status",
    "execution_allowed",
    "overall_execution_status",
    "documentation_sources",
    "record_hash"
  ],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "record_version": {"const": "runtime_capability_audit_v0_1"},
    "audit_date": {"type": "string", "format": "date"},
    "record_status": {"const": "BLOCKED_PENDING_SYNTHETIC_NO_SOURCE_INFERENCE_VERIFICATION"},
    "provider": {"const": "OpenAI"},
    "model_identifier": {"const": "gpt-5.4-mini"},
    "provider_verification_record_path": {"const": "data/studies/human_llm_pilot/provider_model_account_verification_v0_2.json"},
    "provider_verification_record_hash": {"$ref": "#/$defs/hash"},
    "historical_runtime_draft_path": {"const": "data/studies/human_llm_pilot/runtime_settings_draft.json"},
    "historical_runtime_draft_byte_hash": {"$ref": "#/$defs/hash"},
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_identifier",
        "responses_api_access",
        "json_schema_structured_output",
        "reasoning_effort",
        "maximum_output_tokens",
        "temperature",
        "top_p",
        "seed",
        "timeout",
        "retry_count_and_error_classes",
        "parallelism",
        "store",
        "prompt_cache_behavior",
        "data_retention_account_controls"
      ],
      "properties": {
        "model_identifier": {"$ref": "#/$defs/capability"},
        "responses_api_access": {"$ref": "#/$defs/capability"},
        "json_schema_structured_output": {"$ref": "#/$defs/capability"},
        "reasoning_effort": {"$ref": "#/$defs/capability"},
        "maximum_output_tokens": {"$ref": "#/$defs/capability"},
        "temperature": {"$ref": "#/$defs/capability"},
        "top_p": {"$ref": "#/$defs/capability"},
        "seed": {"$ref": "#/$defs/capability"},
        "timeout": {"$ref": "#/$defs/capability"},
        "retry_count_and_error_classes": {"$ref": "#/$defs/capability"},
        "parallelism": {"$ref": "#/$defs/capability"},
        "store": {"$ref": "#/$defs/capability"},
        "prompt_cache_behavior": {"$ref": "#/$defs/capability"},
        "data_retention_account_controls": {"$ref": "#/$defs/capability"}
      }
    },
    "candidate_request_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "api_surface",
        "structured_output_mode",
        "structured_output_strict",
        "store",
        "background_mode",
        "conversation_state",
        "file_inputs",
        "tools",
        "web_search",
        "parallel_provider_calls",
        "request_preservation_required",
        "raw_response_preservation_before_parsing_required",
        "provider_transmission_authorization"
      ],
      "properties": {
        "api_surface": {"const": "Responses API"},
        "structured_output_mode": {"const": "text.format with type json_schema"},
        "structured_output_strict": {"const": true},
        "store": {"const": false},
        "background_mode": {"const": "disabled"},
        "conversation_state": {"const": "none"},
        "file_inputs": {"const": "none"},
        "tools": {"const": "none"},
        "web_search": {"const": "disabled"},
        "parallel_provider_calls": {"const": false},
        "request_preservation_required": {"const": true},
        "raw_response_preservation_before_parsing_required": {"const": true},
        "provider_transmission_authorization": {"const": "BLOCKED"}
      }
    },
    "data_handling_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "api_training_use_policy",
        "standard_abuse_monitoring_retention_may_apply",
        "application_state_retention_depends_on_storage_and_account_controls",
        "zero_data_retention_status",
        "zero_data_retention_claimed",
        "account_level_control_evidence_present"
      ],
      "properties": {
        "api_training_use_policy": {"const": "API inputs are not used for training unless the account opts in"},
        "standard_abuse_monitoring_retention_may_apply": {"const": true},
        "application_state_retention_depends_on_storage_and_account_controls": {"const": true},
        "zero_data_retention_status": {"const": "BLOCKED_UNVERIFIED_ACCOUNT_CONTROL"},
        "zero_data_retention_claimed": {"const": false},
        "account_level_control_evidence_present": {"const": false}
      }
    },
    "synthetic_inference_verification_performed": {"const": false},
    "runtime_frozen": {"const": false},
    "runtime_gate_status": {"const": "BLOCKED_PENDING_SYNTHETIC_NO_SOURCE_INFERENCE_VERIFICATION"},
    "pricing_status": {"const": "BLOCKED_PENDING_POINT_IN_TIME_PRICING_FREEZE"},
    "final_authorization_status": {"const": "BLOCKED"},
    "human_coding_status": {"const": "BLOCKED"},
    "model_execution_status": {"const": "BLOCKED"},
    "execution_allowed": {"const": false},
    "overall_execution_status": {"const": "EXECUTION_BLOCKED"},
    "documentation_sources": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "format": "uri"}
    },
    "record_hash": {"$ref": "#/$defs/hash"}
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "capability_status": {
      "enum": [
        "DOCUMENTED_CANDIDATE",
        "ACCOUNT_METADATA_VERIFIED",
        "REQUIRES_SYNTHETIC_INFERENCE_VERIFICATION",
        "UNSUPPORTED",
        "NOT_APPLICABLE",
        "BLOCKED"
      ]
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "candidate", "evidence_scope", "note"],
      "properties": {
        "status": {"$ref": "#/$defs/capability_status"},
        "candidate": {
          "type": ["string", "number", "integer", "boolean", "null"]
        },
        "evidence_scope": {
          "enum": ["official_documentation_only", "account_metadata", "local_policy", "none"]
        },
        "note": {"type": "string", "minLength": 1, "maxLength": 300}
      }
    }
  }
}
