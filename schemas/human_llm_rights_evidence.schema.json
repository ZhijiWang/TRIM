{
  "$id": "https://github.com/ZhijiWang/TRIM/schemas/human_llm_rights_evidence.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "enum": [
              "RIGHTS_DOCUMENTED_PUBLIC_DOMAIN",
              "RIGHTS_DOCUMENTED_LICENSED"
            ]
          }
        }
      },
      "then": {
        "anyOf": [
          {
            "properties": {
              "evidence_documents": {
                "minItems": 1
              }
            }
          },
          {
            "properties": {
              "evidence_urls_or_citations": {
                "minItems": 1
              }
            }
          }
        ],
        "properties": {
          "edition_rights_basis": {
            "minLength": 1,
            "type": "string"
          },
          "jurisdiction_note": {
            "minLength": 1,
            "type": "string"
          },
          "notes": {
            "minLength": 1,
            "type": "string"
          },
          "publication_or_death_date_evidence": {
            "minLength": 1,
            "type": "string"
          },
          "review_date": {
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "type": "string"
          },
          "reviewer": {
            "minLength": 1,
            "type": "string"
          },
          "rights_basis": {
            "minLength": 1,
            "type": "string"
          },
          "uncertainty": {
            "enum": [
              "low",
              "medium",
              "high"
            ]
          }
        },
        "required": [
          "review_date",
          "reviewer",
          "rights_basis",
          "jurisdiction_note",
          "publication_or_death_date_evidence",
          "edition_rights_basis",
          "notes"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "source_layer": {
            "pattern": "(?i)translation"
          }
        }
      },
      "then": {
        "properties": {
          "translation_rights_basis": {
            "minLength": 1,
            "type": "string"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "RIGHTS_TRANSLATION_REVIEW_REQUIRED"
          }
        }
      },
      "then": {
        "properties": {
          "translation_rights_basis": {
            "minLength": 1,
            "type": "string"
          }
        }
      }
    }
  ],
  "properties": {
    "case_id": {
      "pattern": "^(L1|L2)_[A-Z0-9_]+_[0-9]{3}$",
      "type": "string"
    },
    "edition_rights_basis": {
      "minLength": 1,
      "type": "string"
    },
    "evidence_documents": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array"
    },
    "evidence_urls_or_citations": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array"
    },
    "jurisdiction_note": {
      "minLength": 1,
      "type": "string"
    },
    "notes": {
      "minLength": 1,
      "type": "string"
    },
    "publication_or_death_date_evidence": {
      "minLength": 1,
      "type": "string"
    },
    "record_hash": {
      "description": "SHA-256 over canonical JSON excluding record_hash.",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "type": "string"
    },
    "review_date": {
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "type": [
        "string",
        "null"
      ]
    },
    "reviewer": {
      "minLength": 1,
      "type": "string"
    },
    "rights_basis": {
      "minLength": 1,
      "type": "string"
    },
    "source_identifier": {
      "minLength": 1,
      "type": "string"
    },
    "source_layer": {
      "minLength": 1,
      "type": "string"
    },
    "status": {
      "enum": [
        "RIGHTS_DOCUMENTED_PUBLIC_DOMAIN",
        "RIGHTS_DOCUMENTED_LICENSED",
        "RIGHTS_TRANSLATION_REVIEW_REQUIRED",
        "RIGHTS_SOURCE_REVIEW_REQUIRED",
        "RIGHTS_UNKNOWN_BLOCKED",
        "RIGHTS_NOT_ASSESSED_BLOCKED"
      ]
    },
    "translation_rights_basis": {
      "minLength": 1,
      "type": "string"
    },
    "uncertainty": {
      "enum": [
        "low",
        "medium",
        "high",
        "not_assessed"
      ]
    }
  },
  "required": [
    "case_id",
    "source_layer",
    "source_identifier",
    "rights_basis",
    "jurisdiction_note",
    "publication_or_death_date_evidence",
    "translation_rights_basis",
    "edition_rights_basis",
    "evidence_documents",
    "evidence_urls_or_citations",
    "reviewer",
    "review_date",
    "status",
    "uncertainty",
    "notes",
    "record_hash"
  ],
  "title": "Human-LLM pilot rights evidence record",
  "type": "object"
}
