{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ZhijiWang/TRIM/schemas/human_llm_human_coding_plan.schema.json",
  "title": "Human-LLM pilot blocked human-coding dry-run plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plan_status",
    "created_at",
    "selected_case_count",
    "planned_coder_count",
    "planned_annotation_count",
    "planned_double_coded_count",
    "planned_adjudication_count",
    "manual_manifest_hash",
    "coder_schema_hash",
    "allocation_manifest_hash",
    "rights_gate_status",
    "private_packet_gate_status",
    "coding_environment_status",
    "coder_registry_status",
    "packet_hash_verification_status",
    "final_authorization_status",
    "human_coding_status",
    "actual_packets_inspected",
    "actual_coding_sessions_started",
    "actual_annotations_created",
    "actual_annotations_locked",
    "actual_adjudications_completed",
    "blockers",
    "explicit_blocked_reason",
    "coding_allowed",
    "overall_status",
    "record_hash"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "plan_status": {"const": "DRY_RUN_VALID_HUMAN_CODING_BLOCKED"},
    "created_at": {"type": "string", "format": "date-time"},
    "selected_case_count": {"const": 25},
    "planned_coder_count": {"const": "pending_protocol_freeze"},
    "planned_annotation_count": {"const": "pending_protocol_freeze"},
    "planned_double_coded_count": {"const": "pending_protocol_freeze"},
    "planned_adjudication_count": {"const": "pending_protocol_freeze"},
    "manual_manifest_hash": {"$ref": "#/$defs/hash"},
    "coder_schema_hash": {"$ref": "#/$defs/hash"},
    "allocation_manifest_hash": {"$ref": "#/$defs/hash"},
    "rights_gate_status": {"const": "PASSED_WITH_DOWNSTREAM_GATES_BLOCKED"},
    "private_packet_gate_status": {"const": "PASSED_WITH_CONTROLLED_ACCESS_ONLY"},
    "coding_environment_status": {"const": "DRAFT_UNVERIFIED_BLOCKED"},
    "coder_registry_status": {"const": "SYNTHETIC_DRY_RUN_BLOCKED"},
    "packet_hash_verification_status": {"const": "NOT_PERFORMED"},
    "final_authorization_status": {"const": "BLOCKED"},
    "human_coding_status": {"const": "BLOCKED"},
    "actual_packets_inspected": {"const": 0},
    "actual_coding_sessions_started": {"const": 0},
    "actual_annotations_created": {"const": 0},
    "actual_annotations_locked": {"const": 0},
    "actual_adjudications_completed": {"const": 0},
    "blockers": {
      "type": "array",
      "const": [
        "coding environment unverified",
        "coder eligibility false",
        "coder training incomplete",
        "coder authorization absent",
        "session authorization absent",
        "packet hash verification not performed",
        "final authorization blocked",
        "human-coding gate blocked",
        "record-locking readiness unverified"
      ]
    },
    "explicit_blocked_reason": {"type": "string", "minLength": 1},
    "coding_allowed": {"const": false},
    "overall_status": {"const": "HUMAN_CODING_BLOCKED"},
    "record_hash": {"$ref": "#/$defs/hash"}
  },
  "$defs": {"hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}}
}
