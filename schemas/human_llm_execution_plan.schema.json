{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ZhijiWang/TRIM/schemas/human_llm_execution_plan.schema.json",
  "title": "Human-LLM pilot metadata-only execution plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plan_status",
    "created_at",
    "pr18_reference_head_sha",
    "selected_case_count",
    "condition_count",
    "planned_run_count",
    "ordering_rule",
    "allocation_manifest_hash",
    "prompt_assembly_manifest_hash",
    "manual_manifest_hash",
    "model_response_schema_hash",
    "rights_gate_status",
    "private_packet_gate_status",
    "provider_model_account_gate_status",
    "runtime_gate_status",
    "pricing_gate_status",
    "final_authorization_status",
    "human_coding_status",
    "model_execution_status",
    "provider_calls_planned_but_not_authorized",
    "actual_provider_calls_performed",
    "packets_inspected",
    "requests_transmitted",
    "responses_received",
    "outputs_generated",
    "blockers",
    "explicit_execution_blocked_reason",
    "execution_allowed",
    "overall_execution_status",
    "record_hash"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "plan_status": {"const": "DRY_RUN_VALID_EXECUTION_BLOCKED"},
    "created_at": {"type": "string", "format": "date-time"},
    "pr18_reference_head_sha": {"const": "eac65f27bbe302a17e5f508ac1d516178e917aea"},
    "selected_case_count": {"const": 25},
    "condition_count": {"const": 3},
    "planned_run_count": {"const": 118},
    "ordering_rule": {"type": "string", "minLength": 1},
    "allocation_manifest_hash": {"$ref": "#/$defs/hash"},
    "prompt_assembly_manifest_hash": {"$ref": "#/$defs/hash"},
    "manual_manifest_hash": {"$ref": "#/$defs/hash"},
    "model_response_schema_hash": {"$ref": "#/$defs/hash"},
    "rights_gate_status": {"const": "PASSED_WITH_DOWNSTREAM_GATES_BLOCKED"},
    "private_packet_gate_status": {"const": "PASSED_WITH_CONTROLLED_ACCESS_ONLY"},
    "provider_model_account_gate_status": {"const": "BLOCKED"},
    "runtime_gate_status": {"const": "BLOCKED"},
    "pricing_gate_status": {"const": "BLOCKED"},
    "final_authorization_status": {"const": "BLOCKED"},
    "human_coding_status": {"const": "BLOCKED"},
    "model_execution_status": {"const": "BLOCKED"},
    "provider_calls_planned_but_not_authorized": {"const": 118},
    "actual_provider_calls_performed": {"const": 0},
    "packets_inspected": {"const": 0},
    "requests_transmitted": {"const": 0},
    "responses_received": {"const": 0},
    "outputs_generated": {"const": 0},
    "blockers": {
      "type": "array",
      "const": [
        "provider/model/account account availability",
        "runtime settings",
        "pricing",
        "final authorization",
        "human coding",
        "model execution"
      ]
    },
    "explicit_execution_blocked_reason": {"type": "string", "minLength": 1},
    "execution_allowed": {"const": false},
    "overall_execution_status": {"const": "EXECUTION_BLOCKED"},
    "record_hash": {"$ref": "#/$defs/hash"}
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
  }
}
