{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ZhijiWang/TRIM/schemas/human_llm_model_response.schema.json",
  "title": "Human-LLM pilot model-authored response payload",
  "description": "Study-specific schema for the model-authored annotation payload only. Runtime metadata, hashes, run identifiers, provider metadata, parse status, retry counts, and review linkage are added later by the execution harness.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "selected_evidence",
    "primary_label",
    "friction_locus_proposed",
    "rationale_mechanism",
    "uncertainty",
    "alternative_pathways",
    "counterfactual_tests",
    "candidate_loci",
    "decision_path",
    "review_policy_applied",
    "escalation_required",
    "escalation_reason",
    "free_text_rationale",
    "unresolved_ambiguity"
  ],
  "properties": {
    "selected_evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_id"
      },
      "uniqueItems": true
    },
    "primary_label": {
      "type": [
        "string",
        "null"
      ]
    },
    "friction_locus_proposed": {
      "$ref": "#/$defs/friction_locus"
    },
    "rationale_mechanism": {
      "type": [
        "string",
        "null"
      ]
    },
    "uncertainty": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "low",
        "medium",
        "high",
        "suspended",
        "not_supplied",
        null
      ]
    },
    "alternative_pathways": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/alternative_pathway"
      }
    },
    "counterfactual_tests": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/counterfactual_test"
      }
    },
    "candidate_loci": {
      "$ref": "#/$defs/candidate_loci"
    },
    "decision_path": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "review_policy_applied": {
      "$ref": "#/$defs/review_policy_applied"
    },
    "escalation_required": {
      "type": "boolean"
    },
    "escalation_reason": {
      "type": "string"
    },
    "free_text_rationale": {
      "type": "string"
    },
    "unresolved_ambiguity": {
      "type": "string"
    }
  },
  "$defs": {
    "evidence_id": {
      "type": "string",
      "minLength": 1
    },
    "friction_locus": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "cue_function",
        "warrant_attribution",
        "warrant_relation",
        "operation_function",
        "boundary_setting",
        "temporal_layering",
        "perspective_assignment",
        "context_inference",
        "unresolved",
        null
      ]
    },
    "substantive_friction_locus": {
      "type": "string",
      "enum": [
        "cue_function",
        "warrant_attribution",
        "warrant_relation",
        "operation_function",
        "boundary_setting",
        "temporal_layering",
        "perspective_assignment",
        "context_inference"
      ]
    },
    "candidate_locus_state": {
      "type": "string",
      "enum": [
        "candidate_supported",
        "candidate_not_supported",
        "insufficient_evidence",
        "not_applicable"
      ]
    },
    "candidate_locus": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "category",
        "state",
        "cited_evidence",
        "rationale",
        "confidence"
      ],
      "properties": {
        "category": {
          "$ref": "#/$defs/substantive_friction_locus"
        },
        "state": {
          "$ref": "#/$defs/candidate_locus_state"
        },
        "cited_evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_id"
          },
          "uniqueItems": true
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "not_applicable"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "state": {
                "const": "candidate_supported"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "cited_evidence": {
                "minItems": 1
              }
            }
          }
        }
      ]
    },
    "candidate_loci": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": {
        "$ref": "#/$defs/candidate_locus"
      },
      "uniqueItems": true
    },
    "alternative_pathway": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pathway_id",
        "description",
        "cited_evidence",
        "status"
      ],
      "properties": {
        "pathway_id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "cited_evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_id"
          },
          "uniqueItems": true
        },
        "status": {
          "type": "string",
          "enum": [
            "retained",
            "rejected",
            "unresolved",
            "not_applicable"
          ]
        }
      }
    },
    "counterfactual_test": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "test_id",
        "question",
        "answer",
        "cited_evidence",
        "effect_on_decision",
        "confidence"
      ],
      "properties": {
        "test_id": {
          "type": "string",
          "minLength": 1
        },
        "question": {
          "type": "string"
        },
        "answer": {
          "type": "string"
        },
        "cited_evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_id"
          },
          "uniqueItems": true
        },
        "effect_on_decision": {
          "type": "string"
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "not_applicable"
          ]
        }
      }
    },
    "review_policy_applied": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "category",
        "status",
        "trigger",
        "requires_human_review",
        "final_label_before_review"
      ],
      "properties": {
        "category": {
          "$ref": "#/$defs/friction_locus"
        },
        "status": {
          "type": "string",
          "enum": [
            "standard",
            "review_sensitive",
            "reserved",
            "not_applicable"
          ]
        },
        "trigger": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "requires_human_review": {
          "type": "boolean"
        },
        "final_label_before_review": {
          "$ref": "#/$defs/friction_locus"
        }
      }
    }
  }
}
